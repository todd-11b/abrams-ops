# ───────── Client (browser-exposed, prefixed VITE_*) ─────────
# Anything with VITE_ is bundled into the browser. Do NOT put secrets here.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# GHL key used by the PIN-gated internal consult app at /consult.
# The PIN gate is client-side, so this key is effectively visible to anyone
# who can load the consult bundle. Acceptable for an internal tool; do not
# reuse this key elsewhere.
VITE_GHL_API_KEY=
VITE_GHL_LOCATION_ID=

# Stripe publishable key. Public by design — safe to ship to browser.
VITE_STRIPE_PUBLISHABLE_KEY=

# ───────── Server-only (no VITE_ prefix, never reaches the browser) ─────────
# Used by Vercel edge functions in /api. Required for the public
# /proposal/:contactId route.

GHL_API_KEY=
GHL_LOCATION_ID=

# Used by /api/webhooks/ghl-invoice-paid. Required.
# GHL workflow sends this in the X-Abrams-Webhook-Secret header. Constant-time
# compared on receipt. Generate with: openssl rand -hex 16
GHL_WEBHOOK_SECRET=

# Server-side copy of VITE_GHL_TODD_CONTACT_ID. Required because edge
# functions cannot read VITE_* env vars. Value is the same contact id
# (currently Z3OW0NMGj3sk93ofJuVq).
GHL_TODD_CONTACT_ID=

# Stage ID the invoice-paid webhook moves the GHL opportunity to.
# Fence Production / Job Created stage.
GHL_STAGE_JOB_CREATED=

# Stage ID the invoice-paid webhook moves the GHL opportunity to when
# paymentType=final_balance. Fence Production / Job Complete stage.
GHL_STAGE_JOB_COMPLETE=

# Optional. Comma-separated IP prefixes that GHL outbound webhooks should
# arrive from (e.g. "44.234.,52."). Used for soft logging only — non-matching
# IPs are warned about but still processed. Leave empty to skip the check.
GHL_OUTBOUND_IP_PREFIXES=
