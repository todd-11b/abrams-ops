# ───────── Client (browser-exposed, prefixed VITE_*) ─────────
# Anything with VITE_ is bundled into the browser. Do NOT put secrets here.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# GHL key used by the PIN-gated internal consult app at /consult.
# The PIN gate is client-side, so this key is effectively visible to anyone
# who can load the consult bundle. Acceptable for an internal tool; do not
# reuse this key elsewhere.
VITE_GHL_API_KEY=
VITE_GHL_LOCATION_ID=

# Stripe publishable key. Public by design — safe to ship to browser.
VITE_STRIPE_PUBLISHABLE_KEY=

# ───────── Server-only (no VITE_ prefix, never reaches the browser) ─────────
# Used by Vercel edge functions in /api. Required for the public
# /proposal/:contactId route.

GHL_API_KEY=
GHL_LOCATION_ID=
